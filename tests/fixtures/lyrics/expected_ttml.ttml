<?xml version="1.0" encoding="UTF-8"?>
<tt xmlns="http://www.w3.org/ns/ttml" xmlns:tts="http://www.w3.org/ns/ttml#styling">
  <head>
    <styling>
      <style xml:id="default" tts:fontFamily="sans-serif" tts:fontSize="24px" tts:textAlign="center"/>
    </styling>
  </head>
  <body>
    <div style="default">
      <p begin="00:00:00.000" end="00:00:05.000">花に亡霊</p>
      <p begin="00:00:05.000" end="00:00:10.000">夜に駆ける</p>
      <p begin="00:00:10.000" end="00:00:15.000">星の瞬き</p>
      <p begin="00:00:15.000" end="00:00:20.000">風の音</p>
      <p begin="00:00:20.000" end="00:00:25.000">君の声</p>
      <p begin="00:00:25.000" end="00:00:30.000">遠くで聞こえる</p>
      <p begin="00:00:30.000" end="00:00:35.000">雨の音</p>
      <p begin="00:00:35.000" end="00:00:40.000">心に響く</p>
      <p begin="00:00:40.000" end="00:00:45.000">季節が変わる</p>
      <p begin="00:00:45.000" end="00:00:50.000">時が流れる</p>
      <p begin="00:00:50.000" end="00:00:55.000">君と出会えて</p>
      <p begin="00:00:55.000" end="00:01:00.000">よかった</p>
      <p begin="00:01:00.000" end="00:01:05.000">さよなら</p>
      <p begin="00:01:05.000" end="00:01:10.000">また会う日まで</p>
    </div>
  </body>
</tt>
