│   │   │   ├── converter_page.py  # Audio conversion page
│   │   │   └── settings_page.py   # Settings page
│   │   └── workers/           # Background workers
│   │       └── recognize_worker.py
│   │
│   └── converter/             # Audio conversion module
│       ├── __init__.py
│       ├── config.py          # Converter configuration
